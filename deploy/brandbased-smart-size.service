[Unit]
Description=BrandBased smart-size / crop API (uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/brandbased_smart_sizing
EnvironmentFile=/var/www/brandbased_smart_sizing/.env
ExecStart=/var/www/brandbased_smart_sizing/venv/bin/uvicorn bb_smart_sizing_server:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
